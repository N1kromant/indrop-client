<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
<item android:state_activated="true">
    <shape>
        <stroke android:width="2dp" android:color="?attr/interactiveColor1" />
        <solid android:color="?attr/activeFrontElement" />
        <corners android:radius="8dp" />
    </shape>
</item>
<item>
    <shape>
        <stroke android:width="2dp" android:color="?attr/interactiveColor1" />
        <solid android:color="?attr/frontElement" />
        <corners android:radius="8dp" />
    </shape>
</item>
</selector>